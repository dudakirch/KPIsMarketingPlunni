            type="password"
            id="passwordInput"
            class="login-input"
            placeholder="Senha de acesso"
            autocomplete="current-password"
        />
        <button class="login-btn" onclick="checkPassword()">Entrar</button>
        <p class="login-error" id="loginError">Senha incorreta. Tente novamente.</p>
    </div>
</div>

<!-- ══════════ DASHBOARD ══════════ -->
