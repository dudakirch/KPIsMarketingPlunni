SHORT.forEach((s, pos) => {
    const i = pos + IDX_OFFSET;
    const hasData = DATA[i] != null;

    const tab = document.createElement('button');
    tab.className  = `folder-tab ${hasData ? 'has-data' : 'empty'}`;
    tab.textContent = s;
    tab.dataset.idx = i;
    if (hasData) tab.addEventListener('click', () => activate(i));
    tabsEl.appendChild(tab);

    const panel = document.createElement('div');
    panel.className = 'month-panel';
    panel.id = `panel-${i}`;
    panel.innerHTML = hasData ? buildPanel(DATA[i], i) : `
        <div class="empty-state">
            <div class="icon">📁</div>
            <p>${FULL[i]} · dados ainda não disponíveis</p>
        </div>`;
    panelsEl.appendChild(panel);
});

const lastIdx = Math.max(...Object.keys(DATA).map(Number));
activate(lastIdx);

function activate(idx) {
    document.querySelectorAll('.folder-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.month-panel').forEach(p => p.classList.remove('active'));
    document.querySelector(`[data-idx="${idx}"]`).classList.add('active');
    document.getElementById(`panel-${idx}`).classList.add('active');
}

/* ══════════ HELPERS ══════════ */
function buildLookup(arr) {
    const m = {};
    arr.forEach(k => { m[k.label] = k.value; });
    return m;
}

function parseNum(v) {
    if (v == null) return null;
    const s = String(v)
        .replace(/\./g, '')   // remove thousands dots (pt-BR)
        .replace(',', '.')    // decimal comma → dot
        .replace('+', '')
        .replace('−', '-')
        .replace(/[^0-9.\-]/g, '');
    const n = parseFloat(s);
    return isNaN(n) ? null : n;
}

function calcComp(curr, prev) {
    const c = parseNum(curr);
    const p = parseNum(prev);
    if (c == null || p == null) return null;
    if (p === 0) {
        if (c === 0) return { label: '= sem alteração', type: 'neutral' };
        return { label: `+${c} (novo)`, type: 'positive' };
    }
    const pct = Math.round(((c - p) / Math.abs(p)) * 100);
    if (pct === 0) return { label: '= 0%', type: 'neutral' };
    const arrow = pct > 0 ? '▲' : '▼';
    const sign  = pct > 0 ? '+' : '';
    return { label: `${arrow} ${sign}${pct}%`, type: pct > 0 ? 'positive' : 'negative' };
}

/* ══════════ BUILDERS ══════════ */
function buildPanel(d, idx) {
    // Find closest previous month with data
    let prevD = null;
    for (let pi = idx - 1; pi >= 0; pi--) {
        if (DATA[pi]) { prevD = DATA[pi]; break; }
    }
    const prevIG = prevD ? buildLookup(prevD.instagram) : {};
    const prevLI = prevD ? buildLookup(prevD.linkedin)  : {};
    const prevWS = prevD ? buildLookup(prevD.website)   : {};
    return `
        <div class="month-header">
            <div class="month-name"><span>${d.name}</span></div>
        </div>

        <div class="section">
            <div class="section-label">Redes Sociais</div>
            <div class="platform-block">
                <div class="platform-label instagram">Instagram</div>
                <div class="kpi-grid">${d.instagram.map(k => card(k,'instagram', prevIG[k.label])).join('')}</div>
                ${d.bestPosts ? `
                <div style="margin-top: 28px;">
                    <div class="platform-label instagram" style="margin-bottom: 16px;">Posts em Destaque</div>
                    <div class="posts-grid">
                        ${postCard('Mais visualizações',    d.bestPosts.maisVisualizacoes)}
                        ${postCard('Mais curtidas',         d.bestPosts.maisCurtidas)}
                        ${postCard('Mais comentários',      d.bestPosts.maisComentarios)}
                        ${postCard('Mais compartilhamentos',d.bestPosts.maisCompartilhamentos)}
                    </div>
                </div>` : ''}
            </div>
            <div class="platform-block">
                <div class="platform-label linkedin">LinkedIn</div>
                <div class="kpi-grid">${d.linkedin.map(k => card(k,'linkedin', prevLI[k.label])).join('')}</div>
            </div>
        </div>

        <div class="section">
            <div class="section-label">Website</div>
            <div class="platform-block">
                <div class="kpi-grid">${d.website.filter(k => !k.source).map(k => card(k,'website', prevWS[k.label])).join('')}</div>
                ${d.website.some(k => k.source) ? sourcesBlock(d.website.filter(k => k.source), prevWS) : ''}
                ${d.pageMaisAcessada ? `
                <div class="page-note">
                    Página mais acessada
                    <span class="page-tag">${d.pageMaisAcessada}</span>
                </div>` : ''}
            </div>
        </div>

        ${d.insights ? `
        <div class="section">
            <div class="section-label">Insights do Mês</div>
            <div class="insights-box">
                <p class="insights-text">${d.insights}</p>
            </div>
        </div>` : ''}
    `;
}

function card(k, type, prevVal) {
    const empty = k.value == null;
    const comp  = (!empty && prevVal !== undefined) ? calcComp(k.value, prevVal) : null;
    return `
        <div class="kpi-card ${type}">
            <div class="kpi-label">${k.label}</div>
            <div class="kpi-value${empty ? ' empty' : ''}">${empty ? '—' : k.value}</div>
            ${k.delta !== undefined && k.delta !== '' ? `<div class="kpi-delta ${k.dt}">${k.delta}</div>` : ''}
            ${comp ? `<div class="kpi-comp ${comp.type}">${comp.label}</div>` : ''}
        </div>`;
}

function sourcesBlock(sources, prevWS) {
    // Sort by numeric value descending (nulls last)
    const sorted = [...sources].sort((a, b) => {
        const na = parseNum(a.value) ?? -1;
        const nb = parseNum(b.value) ?? -1;
        return nb - na;
    });

    // Find max value for bar scaling
    const maxVal = Math.max(1, ...sorted.map(k => parseNum(k.value) ?? 0));

    const rows = sorted.map(k => {
        const isNull = k.value == null;
        const num    = isNull ? 0 : (parseNum(k.value) ?? 0);
        const pct    = Math.round((num / maxVal) * 100);
        const comp   = !isNull ? calcComp(k.value, prevWS[k.label]) : null;
        return `
            <div class="source-row">
                <div class="source-row-label">${k.label}</div>
                <div class="source-bar-track">
                    <div class="source-bar-fill${num === 0 ? ' zero' : ''}" style="width:${pct}%"></div>
                </div>
                <div class="source-row-value${isNull ? ' null' : ''}">${isNull ? '—' : k.value}</div>
                <div class="source-row-comp ${comp ? comp.type : ''}">${comp ? comp.label : ''}</div>
            </div>`;
    }).join('');

    return `
        <div class="sources-chart">
            <div class="sources-chart-title">Origem das novas visitas</div>
            ${rows}
        </div>`;
}

function postCard(metricName, data) {
    const isPlaceholder = !data || data.placeholder;

    if (isPlaceholder) {
        return `
            <div class="post-card">
                <div class="post-card-top">
                    <span class="post-metric">${metricName}</span>
                </div>
                <div class="post-image-wrap">
                    <div class="post-image-placeholder">
                        <span>a preencher</span>
                    </div>
                </div>
                <div class="post-metrics-row">
                    ${['Visualizações','Curtidas','Comentários','Compart.'].map(l => `
                    <div class="post-metric-item">
                        <span class="pmi-label">${l}</span>
                        <span class="pmi-value empty">—</span>
                    </div>`).join('')}
                </div>
            </div>`;
    }

    const metrics = [
        { label: 'Visualizações',  val: data.visualizacoes },
        { label: 'Curtidas',       val: data.curtidas },
        { label: 'Comentários',    val: data.comentarios },
        { label: 'Compart.',       val: data.compartilhamentos },
    ];

    const imageHtml = data.imageUrl
        ? `<img src="${data.imageUrl}" alt="${metricName}" />`
        : `<a class="post-image-placeholder" href="${data.url || '#'}" target="_blank" rel="noopener">
               <span>Ver no Instagram ↗</span>
           </a>`;

    return `
        <div class="post-card">
            <div class="post-card-top">
                <span class="post-metric">${metricName}</span>
                ${data.url ? `<a class="post-ver-link" href="${data.url}" target="_blank" rel="noopener">Ver post ↗</a>` : ''}
            </div>
            <div class="post-image-wrap">
                ${imageHtml}
            </div>
            <div class="post-metrics-row">
                ${metrics.map(m => `
                <div class="post-metric-item">
                    <span class="pmi-label">${m.label}</span>
                    <span class="pmi-value${m.val == null ? ' empty' : ''}">${m.val ?? '—'}</span>
                </div>`).join('')}
            </div>
        </div>`;
}
