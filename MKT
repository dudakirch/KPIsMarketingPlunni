<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard de Marketing — Plunni</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Text:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --dark:        #1A1A1A;
            --dark-2:      #242527;
            --pampas:      #F1EFEB;
            --pampas-mid:  #E8E4DF;
            --pampas-dark: #D8D3CC;
            --orange:      #E55C32;
            --orange-soft: rgba(229,92,50,0.12);
            --white:       #FFFFFF;
            --text:        #3F2C28;
            --text-muted:  #9A8E88;
            --border:      #E2DEDA;
            --instagram:   #E1306C;
            --linkedin:    #0077B5;
        }

        body {
            background: var(--dark);
            font-family: 'Inter', -apple-system, sans-serif;
            min-height: 100vh;
            color: var(--text);
        }

        /* ─────────────────────────────
           LOGIN
        ───────────────────────────── */
        #loginScreen {
            position: fixed;
            inset: 0;
            background: var(--dark);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 999;
        }

        .login-wrap {
            background: var(--pampas);
            border-radius: 20px;
            padding: 64px 52px 52px;
            width: 100%;
            max-width: 420px;
            text-align: center;
        }

        .login-asterisk {
            font-size: 28px;
            color: var(--orange);
            margin-bottom: 16px;
            display: block;
        }

        .login-brand {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--orange);
            margin-bottom: 12px;
        }

        .login-title {
            font-family: 'DM Serif Text', serif;
            font-size: 36px;
            color: var(--text);
            line-height: 1;
            margin-bottom: 6px;
        }

        .login-title em { font-style: italic; }

        .login-sub {
            font-size: 12px;
            color: var(--text-muted);
            letter-spacing: 0.04em;
            margin-bottom: 40px;
        }

        .login-input {
            width: 100%;
            padding: 14px 18px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            color: var(--text);
            background: var(--white);
            outline: none;
            transition: border-color 0.2s;
            margin-bottom: 14px;
            letter-spacing: 0.08em;
        }

        .login-input:focus { border-color: var(--orange); }
        .login-input::placeholder { color: var(--text-muted); letter-spacing: 0.02em; }

        .login-btn {
            width: 100%;
            padding: 14px;
            background: var(--orange);
            color: var(--white);
            border: none;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .login-btn:hover { opacity: 0.88; }

        .login-error {
            font-size: 12px;
            color: #DC2626;
            margin-top: 14px;
            display: none;
        }

        /* ─────────────────────────────
           DASHBOARD
        ───────────────────────────── */
        #dashboard {
            display: none;
            padding: 48px 44px 80px;
            max-width: 1380px;
            margin: 0 auto;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 60px;
        }

        .header-brand {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--orange);
            margin-bottom: 10px;
        }

        .header-title {
            font-family: 'DM Serif Text', serif;
            font-size: 52px;
            color: var(--white);
            line-height: 1;
        }

        .header-title em { font-style: italic; }

        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .year-chip {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
            background: rgba(255,255,255,0.06);
            padding: 7px 16px;
            border-radius: 20px;
        }

        .logout-btn {
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.35);
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            border-color: rgba(255,255,255,0.35);
            color: rgba(255,255,255,0.65);
        }

        /* ─────────────────────────────
           FOLDER TABS
        ───────────────────────────── */
        .folder-tabs {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            padding-left: 6px;
            overflow-x: auto;
            scrollbar-width: none;
        }

        .folder-tabs::-webkit-scrollbar { display: none; }

        .folder-tab {
            flex-shrink: 0;
            padding: 9px 18px 11px;
            border-radius: 9px 9px 0 0;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            border: none;
            outline: none;
            cursor: pointer;
            transition: background 0.15s, padding-bottom 0.15s;
            position: relative;
        }

        .folder-tab.empty {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.18);
            cursor: not-allowed;
        }

        .folder-tab.has-data {
            background: var(--pampas-dark);
            color: var(--text);
        }

        .folder-tab.has-data:hover {
            background: var(--pampas-mid);
        }

        .folder-tab.active {
            background: var(--pampas);
            color: var(--text);
            padding-bottom: 13px;
            z-index: 1;
        }

        /* ─────────────────────────────
           FOLDER BODY
        ───────────────────────────── */
        .folder-body {
            background: var(--pampas);
            border-radius: 0 14px 14px 14px;
            padding: 52px 48px;
            min-height: 520px;
        }

        .month-panel { display: none; }

        .month-panel.active {
            display: block;
            animation: fadeUp 0.25s ease;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 380px;
            gap: 14px;
            color: var(--text-muted);
        }

        .empty-state .icon { font-size: 44px; opacity: 0.25; }
        .empty-state p { font-size: 13px; letter-spacing: 0.06em; }

        /* Month header */
        .month-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 44px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border);
        }

        .month-name {
            font-family: 'DM Serif Text', serif;
            font-size: 40px;
            color: var(--text);
        }

        .month-name span { color: var(--orange); }

        /* Section */
        .section { margin-bottom: 48px; }

        .section-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--orange);
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 22px;
        }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* Platform headings */
        .platform-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .platform-label + .kpi-grid { }

        .platform-label.instagram { color: var(--instagram); }
        .platform-label.linkedin  { color: var(--linkedin); }
        .platform-label.website   { color: var(--text-muted); }

        .platform-block { margin-bottom: 28px; }
        .platform-block:last-child { margin-bottom: 0; }

        /* KPI Grid */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(128px, 1fr));
            gap: 10px;
        }

        .kpi-card {
            background: var(--white);
            border-radius: 10px;
            padding: 16px;
            border-top: 3px solid var(--border);
        }

        .kpi-card.instagram { border-top-color: var(--instagram); }
        .kpi-card.linkedin  { border-top-color: var(--linkedin); }
        .kpi-card.website   { border-top-color: var(--text-muted); }

        .kpi-label {
            font-size: 10px;
            color: var(--text-muted);
            line-height: 1.35;
            margin-bottom: 8px;
        }

        .kpi-value {
            font-size: 26px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -0.02em;
            line-height: 1;
        }

        .kpi-value.empty {
            font-size: 20px;
            color: var(--border);
        }

        .kpi-delta {
            font-size: 11px;
            font-weight: 600;
            margin-top: 5px;
        }

        .kpi-delta.positive { color: #15803D; }
        .kpi-delta.negative { color: #DC2626; }

        /* Month-over-month comparison badge */
        .kpi-comp {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 10px;
            font-weight: 600;
            margin-top: 7px;
            padding: 2px 8px;
            border-radius: 20px;
        }

        .kpi-comp.positive { background: rgba(21,128,61,0.1);  color: #15803D; }
        .kpi-comp.negative { background: rgba(220,38,38,0.1);  color: #DC2626; }
        .kpi-comp.neutral  { background: rgba(156,163,175,0.1);color: #9CA3AF; }

        /* Sources bar chart */
        .sources-chart {
            background: var(--pampas-mid);
            border-radius: 10px;
            padding: 16px 20px;
            margin-top: 10px;
        }

        .sources-chart-title {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 14px;
        }

        .source-row {
            display: grid;
            grid-template-columns: 128px 1fr 36px 72px;
            align-items: center;
            gap: 10px;
            padding: 7px 0;
            border-bottom: 1px solid var(--border);
        }

        .source-row:last-child { border-bottom: none; }

        .source-row-label {
            font-size: 11px;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .source-bar-track {
            height: 5px;
            background: var(--border);
            border-radius: 3px;
            overflow: hidden;
        }

        .source-bar-fill {
            height: 100%;
            background: var(--text);
            border-radius: 3px;
            opacity: 0.35;
        }

        .source-bar-fill.zero { width: 0 !important; }

        .source-row-value {
            font-size: 12px;
            font-weight: 700;
            color: var(--text);
            text-align: right;
        }

        .source-row-value.null { color: var(--border); font-weight: 400; }

        .source-row-comp {
            font-size: 10px;
            font-weight: 600;
            text-align: right;
        }

        .source-row-comp.positive { color: #15803D; }
        .source-row-comp.negative { color: #DC2626; }
        .source-row-comp.neutral  { color: #9CA3AF; }

        /* Page tag */
        .page-note {
            margin-top: 14px;
            font-size: 11px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .page-tag {
            display: inline-block;
            background: var(--orange-soft);
            color: var(--orange);
            font-size: 11px;
            font-weight: 600;
            padding: 3px 12px;
            border-radius: 20px;
        }

        /* Insights */
        .insights-box {
            background: var(--white);
            border-radius: 12px;
            padding: 28px 32px;
            border-left: 4px solid var(--orange);
        }

        .insights-text {
            font-size: 15px;
            line-height: 1.85;
            color: var(--text);
        }

        /* Best Posts */
        .posts-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        @media (max-width: 640px) {
            .posts-grid { grid-template-columns: 1fr; }
        }

        .post-card {
            background: var(--white);
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .post-card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px 12px;
        }

        .post-metric {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--instagram);
        }

        .post-ver-link {
            font-size: 10px;
            font-weight: 600;
            color: var(--text-muted);
            text-decoration: none;
            letter-spacing: 0.05em;
            transition: color 0.15s;
        }

        .post-ver-link:hover { color: var(--instagram); }

        /* Image area */
        .post-image-wrap {
            width: 100%;
            aspect-ratio: 1 / 1;
            background: var(--pampas-mid);
            overflow: hidden;
            position: relative;
        }

        .post-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .post-image-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: var(--pampas-mid);
            color: var(--text-muted);
            text-decoration: none;
            transition: background 0.2s;
        }

        .post-image-placeholder:hover { background: var(--pampas-dark); }

        .post-image-placeholder span {
            font-size: 11px;
            letter-spacing: 0.06em;
        }

        /* Metrics row */
        .post-metrics-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-top: 1px solid var(--border);
        }

        .post-metric-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 10px 4px;
            border-right: 1px solid var(--border);
            gap: 2px;
        }

        .post-metric-item:last-child { border-right: none; }

        .pmi-label {
            font-size: 8px;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .pmi-value {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.1;
        }

        .pmi-value.empty { color: var(--border); font-size: 13px; font-weight: 400; }
    </style>
</head>
<body>

<!-- ══════════ LOGIN ══════════ -->
<div id="loginScreen">
    <div class="login-wrap">
        <h1 class="login-title">Market<em>ing</em></h1>
        <p class="login-sub">Dashboard restrito · insira a senha para continuar</p>
